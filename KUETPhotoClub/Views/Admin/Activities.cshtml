@model List<KUETPhotoClub.Models.Activity>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Manage Activities</title>
    <link rel="stylesheet" href="@Url.Content("~/Content/site.css")" />
</head>
<body>
    <div style="max-width:800px; margin:60px auto;">
        <h2>Manage Activities</h2>
        <a href="@Url.Action("Index", "Admin")">← Back to Dashboard</a>
        <hr />

        <h3>Add New Activity</h3>
        <form action="@Url.Action("AddActivity", "Admin")" method="post" enctype="multipart/form-data">
            <input type="text" name="title" placeholder="Activity Title" required
                   style="padding:8px; margin:6px; width:200px;" />
            <input type="text" name="description" placeholder="Description" required
                   style="padding:8px; margin:6px; width:300px;" />
            <input type="file" name="photo" accept="image/*" required style="margin:6px;" />
            <button type="submit"
                    style="padding:8px 20px; background:#7e6e53; color:white; border:none; border-radius:6px;">
                Add Activity
            </button>
        </form>

        <hr />
        <h3>Current Activities</h3>
        <div class="gallery-grid">
            @foreach (var activity in Model)
            {
                <div style="text-align:center;">
                    <img src="@Url.Content(activity.PhotoPath)"
                         style="width:200px; height:200px; object-fit:cover; border-radius:8px;" />
                    <h4>@activity.Title</h4>
                    <p>@activity.Description</p>
                    <form action="@Url.Action("DeleteActivity", "Admin")" method="post">
                        <input type="hidden" name="id" value="@activity.Id" />
                        <button type="submit"
                                style="background:red; color:white; border:none; padding:4px 12px; border-radius:4px;">
                            Delete
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</body>
</html> 